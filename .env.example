GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback when Gemini is rate-limited/quota-limited
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: protect backend endpoints from unauthorized use.
# When set, every request must include header x-opencode-token with the same value.
OPENCODE_AUTH_TOKEN=

# Optional: request caps per IP in a rolling window to protect provider account health.
GEMINI_RATE_LIMIT_WINDOW_MS=60000
GEMINI_RATE_LIMIT_MAX_REQUESTS=20
GEMINI_RATE_LIMIT_MAX_HEAVY_REQUESTS=8
